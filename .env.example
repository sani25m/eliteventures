# API URL for the Elite Ventures backend (optional; defaults to http://localhost:3001)
# VITE_API_URL=http://localhost:3001

# Supabase Auth (optional – for client login, registration, profile, forgot password)
# Get these from Supabase Dashboard → Project Settings → API (use anon/public key here)
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key
